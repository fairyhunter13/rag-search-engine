#!/bin/bash
# GPU-only wrapper for opencode-embedder
# ALWAYS uses GPU (venv with onnxruntime-gpu). Never falls back to CPU.
# If GPU is unavailable, the process exits with a clear error message.
# CPU fallback would cause excessive load and degrade system performance.

DIR="$(dirname "$(readlink -f "$0" 2>/dev/null || realpath "$0" 2>/dev/null || echo "$0")")"
REPO_VENV="$HOME/git/github.com/fairyhunter13/opencode/cmd/opencode-search-engine/embedder/.venv"

# Fix LD_LIBRARY_PATH: strip stale site-packages/nvidia paths from other venvs
# (e.g. cuda-test-venv) and prepend this venv's nvidia libs.
# Must be done in the shell BEFORE exec so the OS dynamic linker picks up the
# correct cuDNN/cuBLAS versions when libonnxruntime_providers_cuda.so loads.
fix_cuda_ld_path() {
  local venv="$1"
  local py_ver
  py_ver="$("$venv/bin/python" -c 'import sys; print(f"python{sys.version_info.major}.{sys.version_info.minor}")' 2>/dev/null)"
  [ -z "$py_ver" ] && return

  local nvidia_base="$venv/lib/$py_ver/site-packages/nvidia"
  [ -d "$nvidia_base" ] || return

  # Build prepend list from this venv's nvidia sub-libraries
  local prepend=""
  for sub in cudnn/lib cublas/lib cuda_runtime/lib curand/lib cusparse/lib cufft/lib nvjitlink/lib cuda_nvrtc/lib nvtx/lib; do
    local libdir="$nvidia_base/$sub"
    [ -d "$libdir" ] && prepend="$libdir${prepend:+:$prepend}"
  done

  # Strip all stale site-packages/nvidia paths from existing LD_LIBRARY_PATH
  local filtered=""
  IFS=: read -ra parts <<< "${LD_LIBRARY_PATH:-}"
  for p in "${parts[@]}"; do
    [[ "$p" == *"site-packages/nvidia"* ]] && continue
    [ -z "$p" ] && continue
    filtered="${filtered:+$filtered:}$p"
  done

  export LD_LIBRARY_PATH="${prepend:+$prepend:}${filtered}"
}

# Check GPU availability. Prints diagnostic info to stderr on failure.
_require_gpu() {
  # Only on Linux
  [ "$(uname -s)" != "Linux" ] && return 1

  # Check if venv exists
  if [ ! -f "$REPO_VENV/bin/python" ]; then
    echo "[embedder-fatal] GPU venv not found at $REPO_VENV" >&2
    echo "[embedder-fatal] Run: cd $REPO_VENV/.. && make sync-gpu" >&2
    return 1
  fi

  # Check if NVIDIA/CUDA is available
  if ! command -v nvidia-smi &> /dev/null; then
    echo "[embedder-fatal] nvidia-smi not found — no NVIDIA driver?" >&2
    return 1
  fi

  if ! nvidia-smi &> /dev/null 2>&1; then
    echo "[embedder-fatal] nvidia-smi fails — GPU not accessible" >&2
    return 1
  fi

  # Verify ONNX Runtime can see CUDA provider
  local cuda_check
  cuda_check=$("$REPO_VENV/bin/python" -c "
import onnxruntime as ort
providers = ort.get_available_providers()
exit(0 if 'CUDAExecutionProvider' in providers else 1)
" 2>&1)
  local rc=$?
  if [ $rc -ne 0 ]; then
    echo "[embedder-fatal] ONNX Runtime CUDA provider not available." >&2
    echo "[embedder-fatal] Check: pip install onnxruntime-gpu and verify CUDA libs." >&2
    echo "[embedder-fatal] Detail: $cuda_check" >&2
    return 1
  fi

  return 0
}

# Main: GPU or die
if _require_gpu; then
  fix_cuda_ld_path "$REPO_VENV"
  exec "$REPO_VENV/bin/python" -m opencode_embedder "$@"
else
  echo "[embedder-fatal] GPU mode is required but unavailable." >&2
  echo "[embedder-fatal] The embedder MUST use the GPU. CPU fallback would cause" >&2
  echo "[embedder-fatal] excessive CPU load (100%+ sustained) and degrade system performance." >&2
  echo "[embedder-fatal] Fix: ensure onnxruntime-gpu with CUDA is installed in the GPU venv." >&2
  exit 1
fi
