{
  "env": {
    "OPENCODE_ALLOW_INDEX_OUTSIDE_CWD": "1"
  },

  "fallbackModel": ["claude-sonnet-4-6", "claude-haiku-4-5"],

  "effortLevel": "xhigh",

  "worktree": {
    "bgIsolation": "none",
    "baseRef": "head"
  },

  "permissions": {
    "allow": [
      "Bash(curl *)",
      "Bash(.venv/bin/ruff check *)",
      "Bash(../.venv/bin/ruff check *)",
      "Bash(journalctl --user *)",
      "Bash(systemctl --user status *)",
      "Bash(systemctl --user is-active *)",
      "Bash(systemctl --user is-enabled *)",
      "Bash(nvidia-smi *)",
      "mcp__opencode-search__search",
      "mcp__opencode-search__overview",
      "mcp__opencode-search__ask",
      "mcp__opencode-search__graph",
      "mcp__opencode-search__federation"
    ]
  },

  "skillOverrides": {
    "deep-research": "user-invocable-only",
    "code-review": "user-invocable-only",
    "security-review": "user-invocable-only",
    "job-search-end-to-end": "off"
  },

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/git/github.com/fairyhunter13/opencode-search-engine/.claude/hooks/session-start.sh",
            "timeout": 8,
            "statusMessage": "Loading session context..."
          }
        ]
      }
    ],

    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/git/github.com/fairyhunter13/opencode-search-engine/.claude/hooks/guard-engine-indexes.sh",
            "timeout": 5,
            "if": "Bash(rm *)"
          }
        ]
      }
    ],

    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/git/github.com/fairyhunter13/opencode-search-engine/.claude/hooks/auto-ruff.sh",
            "timeout": 10,
            "async": true,
            "statusMessage": "Auto-fixing lint..."
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.command // \"\"' | grep -qE '^git (commit|push)' && echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PostToolUse\",\"additionalContext\":\"Git operation completed. Remember zero-unpushed policy: push after every commit.\"}}' || true",
            "timeout": 5,
            "if": "Bash(git commit *)|Bash(git push *)"
          }
        ]
      }
    ],

    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/git/github.com/fairyhunter13/opencode-search-engine/.claude/hooks/stop-check.sh",
            "timeout": 8,
            "statusMessage": "Checking git state..."
          }
        ]
      }
    ],

    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/home/user/git/github.com/fairyhunter13/opencode-search-engine/.claude/hooks/post-compact.sh",
            "timeout": 5,
            "statusMessage": "Restoring project context..."
          }
        ]
      }
    ]
  }
}
