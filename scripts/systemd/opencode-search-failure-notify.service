# Desktop notification on opencode-search daemon crash
# Install: sudo cp this /etc/systemd/system/ && sudo systemctl daemon-reload
[Unit]
Description=opencode-search crash notification
After=opencode-search.service

[Service]
Type=oneshot
ExecStart=/usr/bin/notify-send "opencode-search crashed" "Daemon stopped unexpectedly. Check: journalctl -u opencode-search -n 50"
Environment=DISPLAY=:0
Environment=DBUS_SESSION_BUS_ADDRESS=unix:path=/run/user/1000/bus
